# MyHomestay local environment template
#
# Copy this file to `.env.local` and fill in values from your Supabase project.
# Never commit `.env.local` or any real secret values.

# App URL used for auth redirects, metadata, and absolute links.
# Local development default:
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase project settings.
# Find these in Supabase Dashboard -> Project Settings -> API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-public-key

# Server-only Supabase secret.
# Leave blank until Chapter 4 code explicitly needs it.
# Never expose this in client components or NEXT_PUBLIC_* variables.
SUPABASE_SERVICE_ROLE_KEY=

# Supabase Storage bucket planned for listing photos.
# Create/use this when Chapter 4 photo upload work starts.
SUPABASE_LISTING_PHOTOS_BUCKET=listing-photos
